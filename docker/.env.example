# ── Base de datos ────────────────────────────────────────────
DB_NAME=bachilleratos
DB_USER=clubs_user
DB_PASS=CAMBIA_ESTA_CONTRASEÑA
DB_ROOT_PASS=CAMBIA_ESTA_CONTRASEÑA_ROOT

# ── URL pública del sistema ──────────────────────────────────
# En local:  http://localhost:8080
# En server: https://tudominio.com
BASE_URL=http://localhost:8080

# ── Correo ───────────────────────────────────────────────────
# MAIL_DEMO=true  → no envía correos reales (modo prueba)
# MAIL_DEMO=false → usa las credenciales SMTP de abajo
MAIL_DEMO=true

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@ucol.mx
SMTP_PASS=CONTRASEÑA_APP_GMAIL
SMTP_FROM=tucorreo@ucol.mx
